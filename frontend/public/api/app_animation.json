{
  "title": "追番表",
  "data": {
    "ENDPOINT": "/api/v1/anime",
    "platformMap": {
      "bilibili": "B站",
      "iqiyi": "爱奇艺",
      "youku": "优酷",
      "qq": "腾讯"
    },
    "platformOpts": [
      {
        "label": "哔哩哔哩",
        "value": "bilibili"
      },
      {
        "label": "爱奇艺",
        "value": "iqiyi"
      },
      {
        "label": "优酷",
        "value": "youku"
      },
      {
        "label": "腾讯",
        "value": "qq"
      }
    ],
    "weekMap": {
      "0": "周日",
      "1": "周一",
      "2": "周二",
      "3": "周三",
      "4": "周四",
      "5": "周五",
      "6": "周六"
    },
    "weekOpts": [
      {
        "label": "",
        "children": [
          {
            "label": "周一",
            "value": 1
          },
          {
            "label": "周二",
            "value": 2
          },
          {
            "label": "周三",
            "value": 3
          },
          {
            "label": "周四",
            "value": 4
          },
          {
            "label": "周五",
            "value": 5
          },
          {
            "label": "周六",
            "value": 6
          },
          {
            "label": "周日",
            "value": 0
          }
        ]
      }
    ]
  },
  "toolbar": [
    {
      "type": "button",
      "actionType": "dialog",
      "label": "新增",
      "primary": true,
      "dialog": {
        "title": "新增",
        "body": {
          "type": "form",
          "name": "sample-edit-form",
          "api": "post:${ENDPOINT}",
          "body": [
            {
              "type": "input-text",
              "name": "Name",
              "label": "动画",
              "required": true
            },
            {
              "type": "input-text",
              "name": "Novel",
              "label": "小说"
            },
            {
              "type": "select",
              "name": "PlaybackPlatform",
              "label": "平台",
              "source": "${platformOpts}"
            },
            {
              "type": "select",
              "name": "WeeklyUpdateTime",
              "label": "每周更新",
              "checkAll": true,
              "multiple": true,
              "joinValues": false,
              "extractValue": true,
              "searchable": true,
              "selectMode": "group",
              "source": "${weekOpts}",
              "required": true
            },
            {
              "type": "input-text",
              "name": "Production",
              "label": "制作"
            },
            {
              "type": "input-text",
              "name": "Description",
              "label": "说明"
            },
            {
              "type": "input-number",
              "name": "Rating",
              "label": "评分",
              "precision": 1,
              "step": 0.1
            },
            {
              "type": "input-text",
              "name": "EventId",
              "label": "EventId"
            },
            {
              "type": "input-number",
              "name": "Episode",
              "label": "Episode"
            },
            {
              "type": "input-text",
              "name": "Link",
              "label": "播放链接"
            },
            {
              "type": "input-date",
              "name": "PublishTime",
              "label": "更新时间",
              "format": "YYYY-MM-DD"
            }
          ]
        }
      }
    }
  ],
  "body": {
    "type": "crud",
    "id": "crud_1",
    "syncLocation": false,
    "api": "/api/v1/anime",
    "headerToolbar": [
      {
        "type": "tpl",
        "tpl": "total: ${total}",
        "className": "v-middle"
      }
    ],
    "footerToolbar": [],
    "filter": {
      "debug": false,
      "title": "条件搜索",
      "body": [
        {
          "type": "group",
          "body": [
            {
              "type": "select",
              "name": "PlaybackPlatform",
              "label": "源",
              "source": "${platformOpts}",
              "clearable": true,
              "size": "sm",
              "onEvent": {
                "change": {
                  "actions": [
                    {
                      "componentId": "crud_1",
                      "actionType": "reload",
                      "data": {
                        "PlaybackPlatform": "${PlaybackPlatform}"
                      }
                    }
                  ]
                }
              }
            }
          ]
        }
      ]
    },
    "columns": [
      {
        "name": "ID",
        "label": "ID"
      },
      {
        "name": "Name",
        "label": "动画",
        "copyable": false
      },
      {
        "label": "播放",
        "type": "tpl",
        "tpl": "<a href='${Link}' target='_blank'>第 ${Episode} 集</a>"
      },
      {
        "label": "更新时间",
        "type": "tpl",
        "tpl": "${DATETOSTR(PublishTime, 'YYYY-MM-DD')}"
      },
      {
        "name": "PlaybackPlatform",
        "label": "平台",
        "type": "mapping",
        "source": "${platformMap}"
      },
      {
        "name": "WeeklyUpdateTime",
        "label": "每周更新",
        "type": "mapping",
        "source": "${weekMap}"
      },
      {
        "label": "制作",
        "type": "tpl",
        "tpl": "${Production|truncate:50}",
        "popOver": "${Production}"
      },
      {
        "label": "说明",
        "type": "tpl",
        "tpl": "${Description|truncate:80}",
        "popOver": "${Description}"
      },
      {
        "name": "Rating",
        "label": "评分"
      },
      {
        "type": "operation",
        "label": "操作",
        "buttons": [
          {
            "label": "修改",
            "type": "button",
            "level": "link",
            "actionType": "dialog",
            "dialog": {
              "title": "修改",
              "body": {
                "type": "form",
                "api": "post:${ENDPOINT}",
                "body": [
                  {
                    "type": "input-text",
                    "name": "ID",
                    "label": "ID",
                    "disabled": true
                  },
                  {
                    "type": "input-text",
                    "name": "Name",
                    "label": "动画",
                    "required": true
                  },
                  {
                    "type": "input-text",
                    "name": "Novel",
                    "label": "小说"
                  },
                  {
                    "type": "select",
                    "name": "PlaybackPlatform",
                    "label": "平台",
                    "source": "${platformOpts}"
                  },
                  {
                    "type": "select",
                    "name": "WeeklyUpdateTime",
                    "label": "每周更新",
                    "checkAll": true,
                    "multiple": true,
                    "joinValues": false,
                    "extractValue": true,
                    "searchable": true,
                    "selectMode": "group",
                    "source": "${weekOpts}",
                    "required": true
                  },
                  {
                    "type": "input-text",
                    "name": "Production",
                    "label": "制作"
                  },
                  {
                    "type": "input-text",
                    "name": "Description",
                    "label": "说明"
                  },
                  {
                    "type": "input-number",
                    "name": "Rating",
                    "label": "评分",
                    "precision": 1,
                    "step": 0.1
                  },
                  {
                    "type": "input-text",
                    "name": "EventId",
                    "label": "EventId"
                  },
                  {
                    "type": "input-number",
                    "name": "Episode",
                    "label": "Episode"
                  },
                  {
                    "type": "input-text",
                    "name": "Link",
                    "label": "播放链接"
                  },
                  {
                    "type": "input-date",
                    "name": "PublishTime",
                    "label": "更新时间",
                    "format": "YYYY-MM-DD"
                  }
                ]
              }
            }
          },
          {
            "label": "删除",
            "type": "button",
            "actionType": "ajax",
            "level": "link",
            "className": "text-danger",
            "confirmText": "确认要删除？",
            "api": "delete:${ENDPOINT}/${id}"
          }
        ]
      }
    ]
  }
}